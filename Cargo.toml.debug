[package]
name = "onnx_debug"
version = "0.1.0"
edition = "2021"

[[bin]]
name = "onnx_debug"
path = "onnx_debug.rs"

[dependencies]
ort = { version = "2.1", features = ["download-binaries"] }
tokenizers = "0.15"
dirs = "5"
hf-hub = "0.3"
anyhow = "1"
tokio = { version = "1", features = ["full"] }
log = "0.4"
env_logger = "0.11"
